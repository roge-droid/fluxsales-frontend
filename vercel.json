{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/terms-of-service",
      "destination": "/terms",
      "statusCode": 301
    },
    {
      "source": "/blog/:slug+",
      "destination": "/blog",
      "statusCode": 301
    },
    {
      "source": "/blog1/:path*",
      "destination": "/blog",
      "statusCode": 301
    },
    {
      "source": "/blog_viejo/:path*",
      "destination": "/blog",
      "statusCode": 301
    },
    {
      "source": "/recursos/:path*",
      "destination": "/blog",
      "statusCode": 301
    },
    {
      "source": "/casos-de-estudio/:path*",
      "destination": "/casos",
      "statusCode": 301
    },
    {
      "source": "/en/",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/es/",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/en/:path*",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/es/:path*",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/otras-soluciones",
      "destination": "/",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://93.188.165.81:3001/:path*"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "case.fluxsales.co"
        }
      ],
      "destination": "/case/:path*"
    },
    {
      "source": "/case/:path*",
      "destination": "/case/:path*"
    },
    {
      "source": "/demo/:path*",
      "destination": "/demo/:path*"
    },
    {
      "source": "/diagnostico",
      "destination": "/diagnostico/index.html"
    },
    {
      "source": "/diagnostico-google",
      "destination": "/diagnostico-google/index.html"
    },
    {
      "source": "/repartidores",
      "destination": "/repartidores/index.html"
    },
    {
      "source": "/oferta",
      "destination": "/oferta/index.html"
    },
    {
      "source": "/guias",
      "destination": "/guias/index.html"
    },
    {
      "source": "/guias/:slug",
      "destination": "/guias/:slug/index.html"
    },
    {
      "source": "/pricing",
      "destination": "/pricing/index.html"
    },
    {
      "source": "/about",
      "destination": "/about/index.html"
    },
    {
      "source": "/blog",
      "destination": "/blog/index.html"
    },
    {
      "source": "/casos",
      "destination": "/casos/index.html"
    },
    {
      "source": "/casos/:slug",
      "destination": "/casos/:slug/index.html"
    },
    {
      "source": "/dashboards/:path*",
      "destination": "/dashboards/:path*"
    },
    {
      "source": "/terms",
      "destination": "/legal/terms.html"
    },
    {
      "source": "/privacy",
      "destination": "/legal/privacy.html"
    },
    {
      "source": "/returns",
      "destination": "/legal/returns.html"
    },
    {
      "source": "/data-deletion",
      "destination": "/legal/data-deletion.html"
    },
    {
      "source": "/proposal",
      "destination": "/proposal/index.html"
    },
    {
      "source": "/p/:code",
      "destination": "/p/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/landing/$1"
    }
  ],
  "headers": [
    {
      "source": "/landing/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
