{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://93.188.165.81:3001/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "case.fluxsales.co" }],
      "destination": "/case/:path*"
    },
    {
      "source": "/case/:path*",
      "destination": "/case/:path*"
    },
    {
      "source": "/demo/:path*",
      "destination": "/demo/:path*"
    },
    {
      "source": "/dashboards/:path*",
      "destination": "/dashboards/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/landing/$1"
    }
  ],
  "headers": [
    {
      "source": "/landing/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
